    "commander": "^13.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.14",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^3.0.9"
  }
}
