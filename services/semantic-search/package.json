{
  "name": "@projectmodern/semantic-search",
  "version": "2.0.0",
  "description": "Semantic search service with OpenAI embeddings and pgvector",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "test": "echo 'No tests yet'"
  },
  "dependencies": {
    "@projectmodern/types": "workspace:*",
    "fastify": "^5.2.1",
    "openai": "^4.89.0",
    "pg": "^8.14.1",
    "pgvector": "^0.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.14",
    "@types/pg": "^8.11.11",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vitest": "^3.0.9"
  }
}
