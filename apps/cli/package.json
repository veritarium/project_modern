{
  "name": "@projectmodern/cli",
  "version": "2.0.0",
  "description": "Project Modern CLI - Evaluate and audit open source dependencies",
  "type": "module",
  "bin": {
    "modern": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
