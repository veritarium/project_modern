{
  "name": "@projectmodern/types",
  "version": "2.0.0",
  "type": "module",
  "description": "Shared TypeScript types for Project Modern",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist node_modules"
  },
  "devDependencies": {
    "@projectmodern/config": "workspace:*",
    "@types/node": "20",
    "typescript": "^5.8.0",
    "vitest": "^3.0.9"
  }
}
